{
    "urdf_path": "",
    "output_dir": "output",
    "method": "newton_euler",
    "excitation_only": false,
    "checkpoint_dir": null,

    "joint_limits": {
        "position": null,
        "velocity": null,
        "acceleration": null,
        "torque": null
    },

    "excitation": {
        "basis_functions": "both",
        "optimize_phase": false,
        "num_harmonics": 5,
        "base_frequency_hz": 0.2,
        "optimize_condition_number": true,
        "optimizer_max_iter": 300,
        "trajectory_duration_periods": 1,
        "torque_constraint_method": "none",
        "torque_validation_oversample_factor": 5,
        "torque_constraint": {
            "strict_validation": true,
            "soft_penalty_weight": 100.0,
            "soft_penalty_smoothing": 0.01,
            "relative_uncertainty": 0.1,
            "absolute_uncertainty_floor": 0.001,
            "chance_confidence": 0.99,
            "relative_stddev": 0.05,
            "absolute_stddev_floor": 0.001,
            "envelope_type": "constant",
            "speed_linear_slope": 0.25,
            "velocity_reference": 1.0,
            "min_scale": 0.5,
            "max_scale": 1.5,
            "rms_limit_ratio": null,
            "max_iterations": 3,
            "convergence_tol": 0.01
        }
    },

    "friction": {
        "model": "none"
    },

    "identification": {
        "solver": "ols",
        "parameter_bounds": false,
        "feasibility_method": "none",
        "data_file": null
    },

    "filtering": {
        "enabled": false,
        "cutoff_frequency_hz": 10.0,
        "filter_order": 4
    },

    "downsampling": {
        "frequency_hz": 0
    }
}
