{
    "urdf_path": "",
    "output_dir": "output",

    "stages": {
        "excitation": true,
        "identification": true,
        "validation_pybullet": false,
        "report": false,
        "benchmark": false,
        "plot": false
    },

    "resume": {
        "from_checkpoint": null
    },

    "method": "newton_euler",

    "joint_limits": {
        "position": null,
        "velocity": null,
        "acceleration": null,
        "torque": null
    },

    "excitation": {
        "basis_functions": "both",
        "optimize_phase": false,
        "num_harmonics": 5,
        "base_frequency_hz": 0.2,
        "optimize_condition_number": true,
        "optimizer_max_iter": 300,
        "trajectory_duration_periods": 1,
        "torque_constraint_method": "none",
        "torque_validation_oversample_factor": 5,
        "torque_constraint": {
            "strict_validation": true,
            "soft_penalty_weight": 100.0,
            "soft_penalty_smoothing": 0.01,
            "relative_uncertainty": 0.1,
            "absolute_uncertainty_floor": 0.001,
            "chance_confidence": 0.99,
            "relative_stddev": 0.05,
            "absolute_stddev_floor": 0.001,
            "envelope_type": "constant",
            "speed_linear_slope": 0.25,
            "velocity_reference": 1.0,
            "min_scale": 0.5,
            "max_scale": 1.5,
            "rms_limit_ratio": null,
            "max_iterations": 3,
            "convergence_tol": 0.01
        }
    },

    "friction": {
        "model": "none"
    },

    "identification": {
        "solver": "ols",
        "parameter_bounds": false,
        "feasibility_method": "none",
        "data_file": null,
        "observation_matrix_cache": {
            "save": false,
            "filename": "observation_matrix_cache.npz",
            "load_from": null,
            "force_load": false
        }
    },

    "filtering": {
        "enabled": false,
        "cutoff_frequency_hz": 10.0,
        "filter_order": 4
    },

    "downsampling": {
        "frequency_hz": 0
    },

    "validation_pybullet": {
        "sample_rate_hz": 0,
        "gravity": [0.0, 0.0, -9.80665],
        "use_fixed_base": true,
        "joint_name_order": null,
        "comparison": {
            "tolerance_abs": 0.001,
            "tolerance_normalized_rms": 0.001
        }
    },

    "plot": {
        "format": "png",
        "dpi": 150
    },

    "report": {},
    "benchmark": {},
    "export": {
        "enabled": false,
        "urdf_filename": "adapted_robot.urdf",
        "friction_sidecar": true,
        "friction_sidecar_filename": "adapted_friction.json"
    }
}
