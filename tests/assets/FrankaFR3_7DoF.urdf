<?xml version="1.0"?>
<!-- 7-DOF Franka Research 3 (FR3) Manipulator
     Source: Official Franka Robotics franka_description package
       https://github.com/frankarobotics/franka_description  (tag 2.6.0)
     YAML data files: robots/fr3/{kinematics,joint_limits,inertials,dynamics}.yaml

     This standalone URDF was generated from the official YAML parameter files
     without mesh references, so it can run in any simulator or pipeline
     that only needs kinematics and dynamics (no visual meshes required).

     Kinematic chain (all joints revolute, axis Z in each joint frame):
       joint1: z=+0.333 m from base            (shoulder rotation)
       joint2: roll=-π/2                        (shoulder flexion)
       joint3: y=-0.316, roll=+π/2              (upper arm rotation)
       joint4: x=+0.0825, roll=+π/2             (elbow)
       joint5: x=-0.0825, y=+0.384, roll=-π/2   (wrist rotation)
       joint6: roll=+π/2                        (wrist flexion)
       joint7: x=+0.088, roll=+π/2              (wrist rotation)
       joint8 (fixed): z=+0.107 to flange       (flange frame)

     All inertial parameters are from the official identified model
     (franka_description/robots/fr3/inertials.yaml).
     Joint limits from franka_description/robots/fr3/joint_limits.yaml.
     Dynamics from franka_description/robots/fr3/dynamics.yaml.
-->
<robot name="fr3">

  <link name="world"/>

  <joint name="base_fixed" type="fixed">
    <parent link="world"/>
    <child link="fr3_link0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== link0 (base) ==================== -->
  <link name="fr3_link0">
    <inertial>
      <origin xyz="-0.0172 0.0004 0.0745" rpy="0 0 0"/>
      <mass value="2.3966"/>
      <inertia ixx="0.0090" ixy="0.0000" ixz="0.0020"
               iyy="0.0115" iyz="0.0000"
               izz="0.0085"/>
    </inertial>
  </link>

  <!-- ==================== joint1 ==================== -->
  <joint name="fr3_joint1" type="revolute">
    <parent link="fr3_link0"/>
    <child link="fr3_link1"/>
    <origin xyz="0 0 0.333" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9007" upper="2.9007"
           effort="87.0" velocity="2.62"/>
    <dynamics damping="0.003" friction="0.2"/>
  </joint>

  <!-- ==================== link1 ==================== -->
  <link name="fr3_link1">
    <inertial>
      <origin xyz="0.0000004128 -0.0181251324 -0.0386035970" rpy="0 0 0"/>
      <mass value="2.9274653454"/>
      <inertia ixx="0.023927316485107913" ixy="1.3317903455714081e-05" ixz="-0.00011404774918616684"
               iyy="0.0224821613275756" iyz="-0.0019950320628240115"
               izz="0.006350098258530016"/>
    </inertial>
  </link>

  <!-- ==================== joint2 ==================== -->
  <joint name="fr3_joint2" type="revolute">
    <parent link="fr3_link1"/>
    <child link="fr3_link2"/>
    <origin xyz="0 0 0" rpy="-1.570796326794897 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.8361" upper="1.8361"
           effort="87.0" velocity="2.62"/>
    <dynamics damping="0.003" friction="0.2"/>
  </joint>

  <!-- ==================== link2 ==================== -->
  <link name="fr3_link2">
    <inertial>
      <origin xyz="0.0031828864 -0.0743221644 0.0088146084" rpy="0 0 0"/>
      <mass value="2.9355370338"/>
      <inertia ixx="0.041938946257609425" ixy="0.00020257331521090626" ixz="0.004077784227179924"
               iyy="0.02514514885014724" iyz="-0.0042252158006570156"
               izz="0.06170214472888839"/>
    </inertial>
  </link>

  <!-- ==================== joint3 ==================== -->
  <joint name="fr3_joint3" type="revolute">
    <parent link="fr3_link2"/>
    <child link="fr3_link3"/>
    <origin xyz="0 -0.316 0" rpy="1.570796326794897 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9007" upper="2.9007"
           effort="87.0" velocity="2.62"/>
    <dynamics damping="0.003" friction="0.2"/>
  </joint>

  <!-- ==================== link3 ==================== -->
  <link name="fr3_link3">
    <inertial>
      <origin xyz="0.0407015686 -0.0048200565 -0.0289730823" rpy="0 0 0"/>
      <mass value="2.2449013699"/>
      <inertia ixx="0.02410142547240885" ixy="0.002404694559042109" ixz="-0.002856269270114313"
               iyy="0.01974053266708178" iyz="-0.002104212683891874"
               izz="0.019044494482244823"/>
    </inertial>
  </link>

  <!-- ==================== joint4 ==================== -->
  <joint name="fr3_joint4" type="revolute">
    <parent link="fr3_link3"/>
    <child link="fr3_link4"/>
    <origin xyz="0.0825 0 0" rpy="1.570796326794897 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0770" upper="-0.1169"
           effort="87.0" velocity="2.62"/>
    <dynamics damping="0.003" friction="0.2"/>
  </joint>

  <!-- ==================== link4 ==================== -->
  <link name="fr3_link4">
    <inertial>
      <origin xyz="-0.0459100965 0.0630492960 -0.0085187868" rpy="0 0 0"/>
      <mass value="2.6155955791"/>
      <inertia ixx="0.03452998321913202" ixy="0.01322552265982813" ixz="0.01015142998484113"
               iyy="0.028881621933049058" iyz="-0.0009762833870704552"
               izz="0.04125471171146641"/>
    </inertial>
  </link>

  <!-- ==================== joint5 ==================== -->
  <joint name="fr3_joint5" type="revolute">
    <parent link="fr3_link4"/>
    <child link="fr3_link5"/>
    <origin xyz="-0.0825 0.384 0" rpy="-1.570796326794897 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8763" upper="2.8763"
           effort="12.0" velocity="5.26"/>
    <dynamics damping="0.003" friction="0.2"/>
  </joint>

  <!-- ==================== link5 ==================== -->
  <link name="fr3_link5">
    <inertial>
      <origin xyz="-0.0016039605 0.0292536262 -0.0972965990" rpy="0 0 0"/>
      <mass value="2.3271207594"/>
      <inertia ixx="0.051610278463662895" ixy="-0.005715173387783472" ixz="-0.0035673167625872135"
               iyy="0.04787729713371481" iyz="0.010673985108535986"
               izz="0.016423625579357254"/>
    </inertial>
  </link>

  <!-- ==================== joint6 ==================== -->
  <joint name="fr3_joint6" type="revolute">
    <parent link="fr3_link5"/>
    <child link="fr3_link6"/>
    <origin xyz="0 0 0" rpy="1.570796326794897 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.4398" upper="4.6216"
           effort="12.0" velocity="4.18"/>
    <dynamics damping="0.003" friction="0.2"/>
  </joint>

  <!-- ==================== link6 ==================== -->
  <link name="fr3_link6">
    <inertial>
      <origin xyz="0.0597131221 -0.0410294666 -0.0101692726" rpy="0 0 0"/>
      <mass value="1.8170376524"/>
      <inertia ixx="0.005412333594383447" ixy="0.006193456360285834" ixz="0.0014219289306117652"
