    </inertial>
  </link>

  <!-- ==================== joint7 ==================== -->
  <joint name="fr3_joint7" type="revolute">
    <parent link="fr3_link6"/>
    <child link="fr3_link7"/>
    <origin xyz="0.088 0 0" rpy="1.570796326794897 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0508" upper="3.0508"
