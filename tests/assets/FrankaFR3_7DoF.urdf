    <dynamics damping="0.003" friction="0.2"/>
  </joint>

  <!-- ==================== link7 ==================== -->
  <link name="fr3_link7">
    <inertial>
      <origin xyz="0.0045225817 0.0086261921 -0.0161633251" rpy="0 0 0"/>
      <mass value="0.6271432862"/>
      <inertia ixx="0.00021092389150104718" ixy="-2.433299114461931e-05" ixz="4.564480393778983e-05"
               iyy="0.00017718568002411474" iyz="8.744070223226438e-05"
               izz="5.993190599659971e-05"/>
    </inertial>
  </link>

  <!-- ==================== flange (link8, fixed) ==================== -->
  <link name="fr3_link8">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0"
               iyy="1e-6" iyz="0"
               izz="1e-6"/>
    </inertial>
  </link>

  <joint name="fr3_joint8" type="fixed">
    <parent link="fr3_link7"/>
    <child link="fr3_link8"/>
    <origin xyz="0 0 0.107" rpy="0 0 0"/>
  </joint>

</robot>
